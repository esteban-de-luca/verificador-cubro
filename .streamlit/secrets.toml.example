# .streamlit/secrets.toml.example
# Copia este archivo como .streamlit/secrets.toml y rellena los valores reales.
# NUNCA subas secrets.toml al repositorio (está en .gitignore).

# ---------------------------------------------------------------------------
# Google Drive — Service Account
# ---------------------------------------------------------------------------
[google]
# Pega aquí el contenido del JSON de la Service Account (como string o dict).
# Opción A — como string JSON (más seguro en Streamlit Cloud):
# credentials = '{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token",...}'
#
# Opción B — como sección TOML (más legible localmente):
[google.credentials]
type                        = "service_account"
project_id                  = "tu-proyecto-gcp"
private_key_id              = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "verificador-cubro@tu-proyecto-gcp.iam.gserviceaccount.com"
client_id                   = "000000000000000000000"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/verificador-cubro%40tu-proyecto-gcp.iam.gserviceaccount.com"

# ---------------------------------------------------------------------------
# Google Drive — IDs de carpetas
# ---------------------------------------------------------------------------
[drive]
# ID de la carpeta raíz "Pre Produccion – Verificacion" (zona de cuarentena)
DRIVE_CUARENTENA_ID = "1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ID de la carpeta "Carpintek > 10. Next" (destino tras OK)
DRIVE_CARPINTEK_ID  = "1yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# ---------------------------------------------------------------------------
# Notion
# ---------------------------------------------------------------------------
[notion]
# Token de integración interna (Internal Integration Token)
# Crear en: https://www.notion.so/my-integrations
NOTION_TOKEN = "secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# El ID de la base de datos está hardcodeado en config.py (NOTION_DB_ID)
